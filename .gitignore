# ---------------------------------------------------------------------------
build/
out/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
compile_commands.json
install_manifest.txt
CTestTestfile.cmake
Testing/

# ---------------------------------------------------------------------------
