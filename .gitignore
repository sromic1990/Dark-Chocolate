# ---------------------------------------------------------------------------
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exp
*.pdb
*.ilk
*.idb
*.exe
*.out
*.app
*.dSYM/

# Precompiled headers
*.pch
*.gch
*.pchi

# ---------------------------------------------------------------------------
# Visual Studio / MSVC
# ---------------------------------------------------------------------------
.vs/
*.vcxproj.user
*.suo
*.sdf
*.opensdf
*.VC.db
*.VC.opendb
x64/
x86/
Debug/
Release/
RelWithDebInfo/
MinSizeRel/

# ---------------------------------------------------------------------------
# Xcode (Metal / Metal 4 backend)
# ---------------------------------------------------------------------------
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
*.moved-aside
*.hmap
*.ipa
*.xcuserstate

# ---------------------------------------------------------------------------
# Shader Intermediates
# ---------------------------------------------------------------------------
# SPIR-V (Vulkan / glslang output)
*.spv
*.spvasm

# DXBC / DXIL (DX11 / DX12 compiled shaders)
*.cso
*.dxbc
*.dxil
*.fxo

# Metal shader archives / compiled
*.metallib
*.air
*.metal-ar

# Shader cache directories
shader_cache/
pipeline_cache/

# ---------------------------------------------------------------------------
# GPU Capture / Profiling
# ---------------------------------------------------------------------------
*.gputrace
*.renderdoc
*.rdc
*.nvprof
*.nsight
*.pix

# ---------------------------------------------------------------------------
# Third-Party / Vendor (if fetched at build time)
# ---------------------------------------------------------------------------
# Uncomment if you vendor these via CMake FetchContent or git submodules
# external/
# third_party/
# vendor/

# ---------------------------------------------------------------------------
# Dear ImGui
# ---------------------------------------------------------------------------
imgui.ini

# ---------------------------------------------------------------------------
# Catch2
# ---------------------------------------------------------------------------
# Test runner binaries are already covered by *.exe / *.out above.
# JUnit XML output from CI:
test-results/
*.junit.xml

# ---------------------------------------------------------------------------
# OS Junk
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

